# Parámetros NO secretos de las Cloud Functions (firebase functions:params).
# Copia este archivo a functions/.env y ajusta. El API key NO va aquí:
#   firebase functions:secrets:set OPENROUTER_API_KEY

# Modelo de OpenRouter a usar (barato + empático por defecto).
OPENROUTER_MODEL=openai/gpt-4o-mini

# Instancias mínimas para mitigar cold start (0 = sin costo en reposo).
CHAT_MIN_INSTANCES=0
