{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "brave-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "enabled": true,
      "env": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    },
    "duckduckgo-search": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-duckduckgo"
      ],
      "enabled": true
    }
  }
}
